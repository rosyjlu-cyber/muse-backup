{
  "expo": {
    "name": "Muse",
    "slug": "muse-outfit-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "museoutfitjournal",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EF"
    },
    "ios": {
      "bundleIdentifier": "app.bemymuse.muse",
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Muse uses your contacts to help you find friends to follow."
      }
    },
    "android": {
      "package": "app.bemymuse.muse",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Muse needs access to your photos to log your outfits.",
          "cameraPermission": "Muse needs camera access to capture your daily fit."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b9a3befc-9e85-4cef-a76d-f70beb0efc99"
      }
    }
  }
}
